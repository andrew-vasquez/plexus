PLEXUS_APP_NAME=Plexus API
PLEXUS_APP_VERSION=0.1.0

PLEXUS_INFERENCE_PROVIDER=local
PLEXUS_DEMUCS_MODEL=htdemucs_6s
PLEXUS_GUITAR_STEM_STRATEGY=direct
# direct = raw Demucs guitar stem
# filtered = aggressive harmonic filtering after Demucs
# hybrid_other = raw guitar stem plus recovered harmonics from Demucs other stem
PLEXUS_GUITAR_STEM_RECOVERY_BLEND=0.25
PLEXUS_REFINEMENT_PROVIDER=none
PLEXUS_GUITAR_STEM_HIGHPASS_HZ=70
PLEXUS_GUITAR_STEM_LOWPASS_HZ=1800
PLEXUS_GUITAR_STEM_HARMONIC_MARGIN=3.0
PLEXUS_MAX_UPLOAD_MB=50
